  apiVersion: apps/v1
  kind: Deployment
  metadata:
    name: failover-controller
    namespace: disaster-recovery
  spec:
    replicas: 1
    selector:
      matchLabels:
        app: failover-controller
    template:
      metadata:
        labels:
          app: failover-controller
      spec:
        containers:
